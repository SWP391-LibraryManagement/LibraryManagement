{
  "name": "backend",
  "version": "1.0.0",
  "description": "Approved stack: Node.js + Express.js.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "create-admin": "node scripts/createAdmin.js",
    "test": "jest --runInBand",
    "test:integration:system": "jest --runInBand --runTestsByPath tests/systemIntegration.test.js",
    "test:sql:fe03": "jest --runInBand --testMatch \"**/profileConcurrency.sqltest.js\"",
    "test:sql:fe07": "jest --runInBand --testMatch \"**/*.sqltest.js\"",
    "test:sql:fe05": "jest --runInBand --testMatch \"**/bookConcurrency.sqltest.js\"",
    "test:sql:system": "jest --runInBand --testMatch \"**/systemIntegration.sqltest.js\"",
    "test:coverage": "jest --runInBand --coverage",
    "test:coverage:ci": "jest --runInBand --coverage --coverageReporters=text-summary"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "jest": {
    "collectCoverageFrom": [
      "src/controllers/{borrowing,reservation,notification,report}Controller.js",
      "src/services/{borrowing,reservation,notification,report}Service.js",
      "src/routes/{borrowing,reservation,notification,report}Routes.js",
      "src/validators/{borrowing,reservation,notification,report}Validators.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": ["text-summary", "text"]
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.5.5",
    "nodemailer": "^9.0.0",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
