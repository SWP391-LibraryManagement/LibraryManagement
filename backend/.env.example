PORT=3000

# Generate a local value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_64_character_random_hex_secret

# SQL Server connection
DB_SERVER=localhost
DB_NAME=LibraryManagementDB
DB_PORT=1433
# For SQL Server Express named instance, use DB_INSTANCE_NAME=SQLEXPRESS
# and remove/comment DB_PORT if the instance uses a dynamic port.
# DB_INSTANCE_NAME=SQLEXPRESS
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Use these only if your SQL Server does not use Windows authentication.
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

BCRYPT_COST=10
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=15
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# SMTP email delivery for account verification and password reset.
# Use provider credentials from your local secret store. Do not commit real values.
# Example for Gmail app password:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# MAIL_FROM="Library Management <your_email@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Library Management <no-reply@example.test>"
FRONTEND_BASE_URL=http://localhost:5173
    
