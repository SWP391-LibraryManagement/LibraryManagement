{
  "name": "library-management",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "test:e2e": "playwright test --project=chromium",
    "test:system": "npm --prefix backend run test:integration:system",
    "test:deployment": "node --test tests/deployment/*.test.js",
    "schema:azure:prepare": "node scripts/prepare-azure-schema.js",
    "smoke:staging": "node scripts/smoke-staging.js",
    "docs:screenshots": "playwright test tests/e2e/system-golden-path.spec.js --project=chromium && node scripts/promote-doc-screenshots.js",
    "test:traceability-state": "node --test scripts/traceability-state.test.js",
    "trace": "node scripts/check-traceability.js",
    "trace:enforce": "node scripts/check-traceability.js --enforce --min=70"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.0.0"
  },
  "dependencies": {
    "nodemailer": "^9.0.1"
  }
}
